[Desktop Entry]
Type=Application
Name=NgImageViewer
GenericName=Image Viewer
Comment=View images
Exec=NgImageViewer %F
Icon=ngimageviewer
Terminal=false
Categories=Graphics;Viewer;Photography;
MimeType=image/jpeg;image/png;image/bmp;image/gif;image/webp;image/svg+xml;image/heic;image/heif;image/x-canon-cr2;image/x-canon-cr3;image/x-adobe-dng;
StartupNotify=true
StartupWMClass=NgImageViewer
